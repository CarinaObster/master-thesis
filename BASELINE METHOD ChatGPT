# 4) Walk ranked KG terms to collect up to 3 exact matches for each Excel term
per_excel_examples = {}
for ex_term, ranked_list in excel_to_ranked_kg.items():
    examples = []
    used_indices = set()
    for item in ranked_list:
        kg_t, cos = item["kg_term"], item["cosine"]
        idx = find_first_exact_index(kg_t)
        if idx >= 0 and idx not in used_indices:
            used_indices.add(idx)
            examples.append({
                "kg_term": kg_t,
                "cosine": cos,
                "index": idx,
                "en": english_sentences[idx],
                "de": german_sentences[idx],
            })
        if len(examples) >= TARGET_MATCHES_PER_TERM:
            break
    per_excel_examples[ex_term] = examples

