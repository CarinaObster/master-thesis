# 5) Translate with GPT5 using the term's examples
from google.colab import userdata

def openai_client() -> OpenAI:
    return OpenAI(api_key=userdata.get("OPENAI_API_KEY"))

def build_glossary_block(example: Dict[str, Any], idx: int) -> str:
    return (
        f"{idx}) EN: {example['en']}\n"
        f"   DE: {example['de']}\n"
        f"   (Matched KG term: {example['kg_term']} | cosine={example['cosine']:.3f})"
    )

def build_user_content(examples: List[Dict[str, Any]], source_sentence: str) -> str:
    header = "Context examples (EN→DE):\n"
    blocks = "\n".join(build_glossary_block(ex, i+1) for i, ex in enumerate(examples)) if examples else "(no examples available)\n"
    task = (
        "\nTask: Translate the following English sentence into **German**.\n"
        f"Source sentence (EN): {source_sentence}"
    )
    return header + blocks + task

def translate_with_gpt5(
    sentences: List[str],
    terms_for_rows: List[str],
    examples_by_term: Dict[str, List[Dict[str, Any]]],
    model: str = OPENAI_MODEL
) -> List[str]:
    client = openai_client()
    outputs = []
    for i, (sent, term) in enumerate(zip(sentences, terms_for_rows)):
        examples = examples_by_term.get(term, [])
        user_content = build_user_content(examples, sent)

        if i == 0:  # transparency
            print("----- Example messages sent to OpenAI -----")
            print("[system] You are a precise legal/technical translator.")
            print("[user]")
            print(user_content)
            print("--------------------------------------------------------")

        try:
            resp = client.chat.completions.create(
                model=model,
                messages=[
                    {"role": "system", "content": "You are a precise legal/technical translator."},
                    {"role": "user", "content": user_content},
                ],
                #temperature=0.2,
            )
            txt = (resp.choices[0].message.content or "").strip()
        except Exception as e:
            print(f"[OpenAI] Error on sentence {i}: {e}")
            txt = ""
        outputs.append(txt)
        #if SLEEP_BETWEEN_LLM_CALLS > 0:
            #time.sleep(SLEEP_BETWEEN_LLM_CALLS)
    return outputs

translations = translate_with_gpt5(
