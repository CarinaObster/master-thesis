HEADERS = {"Content-Type": "application/json", "X-Core-ApiKey": API_KEY}

def search_concept(concept: str):
    payload = {"search": {"query": concept, "source_language": "en",
               "select": {"admin": False,"history": False,"languages": ["de","en"],
                          "concept_properties": False,"term_properties": ["Term Type"],"relations": True}}}
    try:
        r = requests.post(f"{BASE_URL}/concepts/search", json=payload, headers=HEADERS, timeout=30)
        return r.json().get("hits", []) if r.status_code == 200 else []
    except Exception as e:
        print("🚨 API error:", e); return []

def search_concept_fallback_iterative(concept: str, min_prefix_len=2, max_prefix_len=5):
    max_prefix_len = min(max_prefix_len, len(concept))
    for L in range(max_prefix_len, min_prefix_len - 1, -1):
        q = concept[:L] + "*"
        payload = {"search":{"query": q, "source_language": "en",
                    "select":{"admin": False,"history": False,"languages": ["de","en"],
                              "concept_properties": False,"term_properties": ["Term Type"],"relations": True}}}
        try:
            r = requests.post(f"{BASE_URL}/concepts/search", json=payload, headers=HEADERS, timeout=30)
            hits = r.json().get("hits", []) if r.status_code == 200 else []
            if len(hits) > 1:
                return hits
        except Exception as e: print("🚨 API error (fallback):", e); return []
    return []

def fetch_candidate_terms_from_kg(query: str) -> List[str]:
    """Return deduped list of English KG terms for a query."""
    hits = search_concept(query)
    if len(hits) <= 1:
        fh = search_concept_fallback_iterative(query)
        if fh: hits = fh
    terms_en = []
    for h in hits:
        res = h.get("result", {})
        for t in res.get("terms", []):
            if t.get("lang") == "en":
                v = t.get("value", "")
                if v:
                    terms_en.append(v)
    # Dedupe + drop identical to source term
    out, seen = [], set()
    src_lower = query.lower()
    for t in terms_en:
        if t.lower() == src_lower:
            continue
        if t not in seen:
            out.append(t); seen.add(t)
    return out

