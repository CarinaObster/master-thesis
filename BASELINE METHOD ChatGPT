# Precompute lowercase EN sentences for fast substring checks
english_sentences_lower = [s.lower() for s in english_sentences]

def find_first_exact_index(term: str) -> int:
    """Return first index of exact (case-insensitive) substring match in EN sentences, or -1 if none."""
    tl = term.lower()
    for i, en_l in enumerate(english_sentences_lower):
        if tl in en_l:
            return i
    return -1

