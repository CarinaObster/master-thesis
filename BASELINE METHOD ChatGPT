# Facebook Contriever Setup
retriever_model_name = "facebook/contriever"
tokenizer = AutoTokenizer.from_pretrained(retriever_model_name)
retriever = AutoModel.from_pretrained(retriever_model_name).eval().to(device)

@torch.no_grad()
def embed_texts(texts: List[str], batch_size: int = 64):
    embs = []
    for i in range(0, len(texts), batch_size):
        batch = texts[i:i+batch_size]
        inputs = tokenizer(batch, padding=True, truncation=True, return_tensors="pt").to(device)
        out = retriever(**inputs).last_hidden_state[:, 0]
        embs.append(out.detach().cpu())
    return torch.cat(embs, dim=0)

def rank_all_kg_terms_for_source(source_term: str, kg_terms: List[str]) -> List[Dict[str, Any]]:
    """Return ALL KG terms sorted by cosine similarity."""
    if not kg_terms:
        return []
    texts = [source_term] + kg_terms
    embs = F.normalize(embed_texts(texts), p=2, dim=1)  # (1+K, D)
    sims = (embs[0:1] @ embs[1:].T).squeeze(0).tolist()
    paired = [{"kg_term": kg_terms[i], "cosine": float(sims[i])} for i in range(len(kg_terms))]
    paired.sort(key=lambda x: x["cosine"], reverse=True)
    return paired

